# ============================================================
# Projeto ENS — env central única
# Copie para .env e preencha valores reais. Não commitar .env.
# ============================================================

# ---------- Ambiente ----------
NEXUS_ENV=local
NEXUS_COMPOSE_PROJECT_NAME=projeto-ens
NEXUS_INTERNAL_NETWORK=projeto-ens-internal

# ---------- Portas locais ----------
NEXUS_CHAT_WEB_PORT=8088
NEXUS_CHAT_BRIDGE_PORT=8081
NEXUS_RAG_MCP_PORT=8000
NEXUS_GRAPH_MCP_PORT=8010
NEXUS_HERMES_API_PORT=8652
NEXUS_HERMES_KANBAN_PORT=9119
NEXUS_DESIGNER_API_PORT=8090
NEXUS_ARTIFACT_PORT=8095
NEXUS_MARKETING_OPS_PORT=8091

# ---------- URLs públicas/locais usadas pelo browser ----------
# Local WSL defaults. On VPS/prod, replace with HTTPS domains below.
NEXUS_PUBLIC_CHAT_WEB_URL=http://127.0.0.1:8088
NEXUS_PUBLIC_CHATBOT_PROXY_URL=http://127.0.0.1:8081
NEXUS_PUBLIC_DESIGNER_API_URL=http://127.0.0.1:8090
NEXUS_PUBLIC_ARTIFACT_URL=http://127.0.0.1:8095
NEXUS_PUBLIC_MARKETING_OPS_URL=http://127.0.0.1:8091
NEXUS_PUBLIC_CHAT_STREAM_FILE_HOSTS=127.0.0.1,localhost

# ---------- Produção VPS / Traefik ----------
# Used by docker-compose.prod.yml. Set these in .env on the VPS before build.
# Traefik runs in a separate Compose stack with network_mode: host and Docker provider.
# This project does NOT create/run a second Traefik and does NOT require an external traefik Docker network.
NEXUS_TRAEFIK_CERT_RESOLVER=letsencrypt
NEXUS_PUBLIC_APP_HOST=app.solucoes-nexus.tech
NEXUS_PUBLIC_BRIDGE_HOST=bridge.solucoes-nexus.tech
NEXUS_PUBLIC_DESIGNER_HOST=designer.solucoes-nexus.tech
NEXUS_PUBLIC_ARTIFACT_HOST=arquivos.solucoes-nexus.tech
NEXUS_PUBLIC_HERMES_API_HOST=api-hermes.solucoes-nexus.tech
NEXUS_PUBLIC_HERMES_DASHBOARD_HOST=hermes.solucoes-nexus.tech
NEXUS_PUBLIC_MARKETING_OPS_HOST=ops.solucoes-nexus.tech
# VPS browser-facing URLs. These values are baked into the frontend image at build time.
# For VPS/prod, uncomment/override the local defaults below in .env:
# NEXUS_PUBLIC_CHAT_WEB_URL=https://app.solucoes-nexus.tech
# NEXUS_PUBLIC_CHATBOT_PROXY_URL=https://bridge.solucoes-nexus.tech
# NEXUS_PUBLIC_DESIGNER_API_URL=https://designer.solucoes-nexus.tech
# NEXUS_PUBLIC_ARTIFACT_URL=https://arquivos.solucoes-nexus.tech
# NEXUS_PUBLIC_CHAT_STREAM_FILE_HOSTS=app.solucoes-nexus.tech,bridge.solucoes-nexus.tech,designer.solucoes-nexus.tech,arquivos.solucoes-nexus.tech

# ---------- CORS / allowed origins ----------
NEXUS_CHAT_ALLOWED_ORIGINS=http://127.0.0.1:8088,http://localhost:8088
NEXUS_DESIGNER_ALLOWED_ORIGINS=http://127.0.0.1:8088,http://localhost:8088
NEXUS_ARTIFACT_ALLOWED_ORIGINS=http://127.0.0.1:8088,http://localhost:8088
NEXUS_MARKETING_OPS_ALLOWED_ORIGINS=http://127.0.0.1:8088,http://localhost:8088
NEXUS_HERMES_ALLOWED_HOSTS=127.0.0.1,localhost,hermes-api

# ---------- Artifact Server local/privado ----------
NEXUS_ARTIFACT_INTERNAL_KEY=CHANGE_ME_STRONG_RANDOM
NEXUS_ARTIFACT_ACCESS_TOKEN_SECRET=CHANGE_ME_STRONG_RANDOM
NEXUS_ARTIFACT_INTERNAL_URL=http://artifact-server:8095
NEXUS_HERMES_ARTIFACTS_DIR=/opt/data/nexus-artifacts
NEXUS_BRIDGE_HERMES_ARTIFACTS_DIR=/app/data/hermes-artifacts
# Limite por arquivo/artifact individual (5 GiB); nao define cota total do storage local.
NEXUS_ARTIFACT_MAX_UPLOAD_BYTES=5368709120
NEXUS_ARTIFACT_ACCESS_TOKEN_TTL_SECONDS=900
NEXUS_ARTIFACT_MAX_ACCESS_TOKEN_TTL_SECONDS=3600

# ---------- Hermes response contracts ----------
# Keep both enabled for the ENS/NexusAI chat. Memory routing adds RAG/Graph context;
# Humanizer keeps every Hermes answer natural without requiring an explicit /humanizer call.
NEXUS_MEMORY_ROUTING_CONTRACT_ENABLED=true
NEXUS_HUMANIZER_RESPONSE_CONTRACT_ENABLED=true

# ---------- Supabase ----------
# Mantemos URLs/chaves por domínio para não perder funcionalidade caso os projetos isolados usem Supabase diferentes.
NEXUS_APP_SUPABASE_URL=https://SEU-APP.supabase.co
NEXUS_APP_SUPABASE_ANON_KEY=CHANGE_ME
NEXUS_APP_SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME
NEXUS_RAG_SUPABASE_URL=https://SEU-RAG.supabase.co
NEXUS_RAG_SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME
NEXUS_DESIGNER_SUPABASE_URL=https://SEU-DESIGNER.supabase.co
NEXUS_DESIGNER_SUPABASE_ANON_KEY=CHANGE_ME
NEXUS_DESIGNER_SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME
NEXUS_SUPABASE_PROJECT_REF=
NEXUS_SUPABASE_PROJECT_ID=
NEXUS_SUPABASE_DB_PASSWORD=
# Use the Supabase Session pooler URL (port 5432), NOT the direct connection URL.
# Direct connections resolve to IPv6-only, which is unreachable from Docker containers
# on most VPS hosts. The Session pooler provides IPv4 access with identical behaviour.
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
NEXUS_SUPABASE_DATABASE_URL=
NEXUS_SUPABASE_JWT_SECRET=
NEXUS_SUPABASE_ACCESS_TOKEN=
NEXUS_CHAT_ATTACHMENTS_BUCKET=chat-attachments
NEXUS_SUPABASE_OUTPUTS_BUCKET=image-gen-outputs
NEXUS_SUPABASE_GENERATED_IMAGES_PREFIX=hermes-chat-images
NEXUS_SUPABASE_OUTPUTS_METADATA_ENABLED=false
NEXUS_SUPABASE_SIGNED_URL_EXPIRES_SECONDS=604800
NEXUS_SUPABASE_UPLOAD_MAX_ATTEMPTS=3
NEXUS_SUPABASE_UPLOAD_BACKOFF_SECONDS=2
NEXUS_HERMES_IMAGE_SUPABASE_DELETE_LOCAL_CACHE=true

# ---------- Marketing Ops ----------
# PostgreSQL URL acima pertence ao Supabase do app. Nunca use a URL do Supabase do RAG.
NEXUS_MARKETING_OPS_INTERNAL_KEY=CHANGE_ME_STRONG_RANDOM
NEXUS_MARKETING_OPS_MCP_URL=http://marketing-ops:8091/mcp
NEXUS_MARKETING_OPS_DELEGATION_ACTIVE_KID=v1
NEXUS_MARKETING_OPS_DELEGATION_ACTIVE_KEY=CHANGE_ME_STRONG_RANDOM_AT_LEAST_32_BYTES
NEXUS_MARKETING_OPS_DELEGATION_PREVIOUS_KID=
NEXUS_MARKETING_OPS_DELEGATION_PREVIOUS_KEY=
NEXUS_MARKETING_OPS_DELEGATION_TTL_SECONDS=90
NEXUS_MARKETING_OPS_DELEGATION_MAX_TTL_SECONDS=120
# Tokens continuam curtos; o Bridge pode renova-los somente enquanto a run pai estiver ativa.
NEXUS_MARKETING_OPS_DELEGATION_REFRESH_WINDOW_SECONDS=900
# O workspace limita cada material de campanha a 25 MiB; o Artifact Server
# mantem separadamente seu limite global por artefato em NEXUS_ARTIFACT_MAX_UPLOAD_BYTES.
NEXUS_MARKETING_OPS_ARTIFACT_TIMEOUT_MS=5000
NEXUS_MARKETING_OPS_RAG_URL=http://rag-mcp:8000/mcp
NEXUS_MARKETING_OPS_RAG_TIMEOUT_MS=5000
NEXUS_MARKETING_OPS_TENANT_TIME_ZONE=America/Sao_Paulo
NEXUS_MARKETING_OPS_FEATURE_READ=false
NEXUS_MARKETING_OPS_FEATURE_WRITE=false
NEXUS_MARKETING_OPS_FRONTEND_ENABLED=false
NEXUS_MARKETING_OPS_FRONTEND_READ=false
NEXUS_MARKETING_OPS_FRONTEND_WRITE=false
NEXUS_MARKETING_OPS_FRONTEND_KILL_SWITCH=false

# Gate E2E integrado da Fase 2. Permanecera desabilitado ate a execucao
# controlada na VPS, com contas e fixtures exclusivas para validacao.
MARKETING_OPS_E2E_ENABLED=false
MARKETING_OPS_E2E_BASE_URL=https://app.example.invalid
MARKETING_OPS_E2E_MEMBER_EMAIL=phase2-member@example.invalid
MARKETING_OPS_E2E_MEMBER_PASSWORD=CHANGE_ME_E2E_MEMBER_PASSWORD
MARKETING_OPS_E2E_MANAGER_EMAIL=phase2-manager@example.invalid
MARKETING_OPS_E2E_MANAGER_PASSWORD=CHANGE_ME_E2E_MANAGER_PASSWORD
MARKETING_OPS_E2E_ADMIN_EMAIL=phase2-admin@example.invalid
MARKETING_OPS_E2E_ADMIN_PASSWORD=CHANGE_ME_E2E_ADMIN_PASSWORD
MARKETING_OPS_E2E_VIEWER_CAMPAIGN_ID=
MARKETING_OPS_E2E_CANDIDATE_NAME=
MARKETING_OPS_E2E_EXISTING_ARTIFACT_ID=
MARKETING_OPS_E2E_COURSE_QUERY=
MARKETING_OPS_E2E_COURSE_TITLE=

# ---------- Hermes Agent/API/Kanban ----------
NEXUS_HERMES_API_KEY=CHANGE_ME_STRONG_RANDOM
NEXUS_HERMES_API_BASE_URL=http://127.0.0.1:8652
NEXUS_HERMES_MODEL_NAME=hermes-agent
NEXUS_HERMES_SESSIONS_API_ENABLED=true
NEXUS_HERMES_RUN_POLL_MS=2000
NEXUS_HERMES_GATEWAY_ALLOW_ALL_USERS=true
NEXUS_HERMES_KANBAN_AUTH_USER=NexusAI
NEXUS_HERMES_KANBAN_AUTH_PASSWORD_HASH=CHANGE_ME_HTPASSWD_HASH_ESCAPED
NEXUS_HERMES_STREAM_TIMEOUT_MS=120000
NEXUS_HERMES_REQUEST_TIMEOUT_MS=120000


# ---------- Neo4j / Graph MCP white-label ----------
# Neo4j 5.x Community; usado pelo Nexus Graph MCP interno.
NEXUS_NEO4J_USER=neo4j
NEXUS_NEO4J_PASSWORD=nexus-neo4j
NEXUS_GRAPH_URL=bolt://neo4j:7687
NEXUS_GRAPH_BACKEND=neo4j-multi-tenant-user
NEXUS_GRAPH_MCP_URL=http://graph-mcp:8010/mcp
NEXUS_GRAPH_DATABASE=neo4j
NEXUS_GRAPH_DATABASE_STRATEGY=shared
NEXUS_GRAPH_BOOTSTRAP_ON_START=true
NEXUS_TENANT_ID=ens
NEXUS_RAG_INTERNAL_URL=http://rag-mcp:8000/internal/graph-sync/sources
NEXUS_INTERNAL_SYNC_KEY=
NEXUS_MEMORY_ROUTING_CONTRACT_ENABLED=true

# ---------- Provedores LLM / IA ----------
NEXUS_OPENROUTER_API_KEY=
NEXUS_OPENAI_API_KEY=
NEXUS_ANTHROPIC_API_KEY=
NEXUS_GEMINI_API_KEY=
NEXUS_GOOGLE_API_KEY=

# ---------- RAG MCP / ENS ----------
NEXUS_RAG_MCP_CONFIG=/app/config/ens-rag-mcp.yaml
NEXUS_RAG_MCP_URL=http://127.0.0.1:8000/mcp
NEXUS_ENS_API_URL=
NEXUS_ENS_API_KEY=
NEXUS_ENS_API_KEY_HEADER=x-api-key
NEXUS_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
NEXUS_OPENAI_EMBEDDING_BASE_URL=
NEXUS_OPENAI_CHAT_BASE_URL=
NEXUS_RAG_RERANKER_MODE=local
NEXUS_RAG_RERANKER_MODEL=gpt-4o-mini
NEXUS_TZ=America/Sao_Paulo
NEXUS_RAG_INGEST_ACTOR_PROFILE=ceo
NEXUS_RAG_INGEST_CRON_SCHEDULE=0 7 * * 1
NEXUS_RAG_MANUAL_SEED_PATH=

# ---------- Nexus Designer ----------
NEXUS_DESIGNER_OUTPUTS_DIR=./data/designer/outputs
NEXUS_DESIGNER_TMP_DIR=./data/designer/tmp
NEXUS_DESIGNER_OPENAI_MODEL=gpt-4o-mini
NEXUS_DESIGNER_IMAGEN_MODEL=imagen-4.0-generate-preview-06-06
NEXUS_DESIGNER_IMAGE_SIZE=1024x1024
NEXUS_DESIGNER_IMAGE_ASPECT_RATIO=1:1
NEXUS_DESIGNER_GEMINI_MODEL=gemini-2.5-pro
NEXUS_DESIGNER_GEMINI_PLANNER_MODEL=gemini-2.5-pro
NEXUS_DESIGNER_GEMINI_REFINER_MODEL=
NEXUS_DESIGNER_GEMINI_VALIDATOR_MODEL=
NEXUS_DESIGNER_MAX_SAFETY_RETRIES=3
NEXUS_DESIGNER_ENABLE_STEP1_PLANNER=true
NEXUS_DESIGNER_ENABLE_STEP2_PLANNER=true
NEXUS_DESIGNER_ENABLE_STEP3_PLANNER=true
NEXUS_DESIGNER_ENABLE_STEP3_PERSONA_LOCK_VALIDATION=true
NEXUS_DESIGNER_EXECUTOR_SINGLE_IMAGE_MODE=true
NEXUS_DESIGNER_STEP3_MAX_CORRECTION_ROUNDS=2
NEXUS_DESIGNER_DELIVERY_SHARPEN_RADIUS=1
NEXUS_DESIGNER_DELIVERY_SHARPEN_PERCENT=150
NEXUS_DESIGNER_DELIVERY_SHARPEN_THRESHOLD=3
NEXUS_DESIGNER_GENAI_MAX_RETRIES=3
NEXUS_DESIGNER_GENAI_MAX_RETRIES_RESOURCE_EXHAUSTED=6
NEXUS_DESIGNER_GENAI_RETRY_BASE_SECONDS=2
NEXUS_DESIGNER_WORKER_THREADS=2
NEXUS_DESIGNER_MIN_SECONDS_BETWEEN_PIECES=0

# ---------- Integrações/testes auxiliares preservadas ----------
NEXUS_N8N_URL=
NEXUS_N8N_API_KEY=
NEXUS_DATABASE_URL=
NEXUS_RUN_SESSION_PREFIX=
