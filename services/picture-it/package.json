{
  "name": "picture-it",
  "version": "0.2.2",
  "description": "Photoshop for AI agents. Composable image operations from the CLI.",
  "module": "./index.ts",
  "type": "module",
  "bin": {
    "picture-it": "./dist/index.js"
  },
  "files": [
    "dist",
    "fonts",
    "README.md",
    "hero-v2.png"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "start": "bun run index.ts",
    "dev": "bun run index.ts",
    "download-fonts": "bun run scripts/download-fonts.ts",
    "prepublishOnly": "bun run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geongeorge/picture-it.git"
  },
  "homepage": "https://github.com/geongeorge/picture-it#readme",
  "bugs": {
    "url": "https://github.com/geongeorge/picture-it/issues"
  },
  "keywords": [
    "ai",
    "image",
    "cli",
    "graphics",
    "open-graph",
    "social-images",
    "satori",
    "fal"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@fal-ai/client": "^1.9.5",
    "@resvg/resvg-js": "^2.6.2",
    "commander": "^14.0.3",
    "satori": "^0.26.0",
    "sharp": "^0.34.5"
  }
}
