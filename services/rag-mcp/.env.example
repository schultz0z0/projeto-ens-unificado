NODE_ENV=production
NEXUSAI_RAG_MCP_CONFIG=config/nexusai-rag-mcp.yaml
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me

# ENS client ingestion source.
ENS_API_URL=https://example.com/ens-courses-json
ENS_API_KEY=replace-me
ENS_API_KEY_HEADER=key

# Optional embeddings. Without this, ingestion stores text chunks only.
OPENAI_API_KEY=replace-me
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1

# NexusAI manual seed.
NEXUSAI_MANUAL_SEED_PATH=data/seeds/nexusai-example-content.json
