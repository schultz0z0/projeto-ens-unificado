# ============================================================
# Nexus/Hermes VPS Linux example env
# Copy to .env on the VPS and fill real values there.
# Do NOT commit real secrets.
# ============================================================

COMPOSE_PROJECT_NAME=nexus-hermes

# Traefik already exists on the VPS. Set this to the Docker network used by Traefik.
# Check on VPS with: docker network ls
TRAEFIK_NETWORK=traefik
TRAEFIK_CERT_RESOLVER=letsencrypt

# Public domains - keep these stable
HERMES_API_SUBDOMAIN=api-hermes.solucoes-nexus.tech
HERMES_KANBAN_SUBDOMAIN=hermes.solucoes-nexus.tech

# Internal service ports. They are bound to 127.0.0.1 for SSH/debug only;
# public access should go through Traefik HTTPS.
HERMES_PUBLIC_PORT=8652
HERMES_API_PORT_CORE=8652
HERMES_KANBAN_PUBLIC_PORT=9119
HERMES_KANBAN_PORT=9119

# Hermes API auth. Replace on VPS.
HERMES_API_KEY_CORE=58ab03854d585d9bb8d245fa4e83e00014eb032032236fd96f32ccaeff0422c5
GATEWAY_ALLOW_ALL_USERS=true

# Kanban Basic Auth for Traefik. Replace on VPS.
# IMPORTANT: this must be an htpasswd hash, not the plain password.
# Generate on Linux, then escape $ for Docker Compose interpolation:
#   HASH=$(openssl passwd -apr1 'your-password')
#   printf '%s\n' "$HASH" | sed 's/\$/$$/g'
# Or with apache2-utils:
#   htpasswd -nbm NexusAI 'your-password' | sed -E 's/^([^:]+)://; s/\$/$$/g'
HERMES_KANBAN_AUTH_USER=NexusAI
HERMES_KANBAN_AUTH_PASSWORD_HASH=$$apr1$$example$$replace_with_real_escaped_hash

# LLM provider examples - keep only what you actually use.
# Configure the final model/provider on the VPS with `hermes setup` or `hermes model`.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Hermes + MCP memory routing.
# Keep Hermes native memory enabled; these MCP layers add RAG/Graph context on top.
NEXUS_TENANT_ID=ens
NEXUS_GRAPH_MCP_URL=http://graph-mcp:8010/mcp
NEXUS_PICTURE_MCP_URL=http://picture-it:8090/mcp
NEXUS_PICTURE_MCP_TIMEOUT=300
NEXUS_PICTURE_MCP_CONNECT_TIMEOUT=20
NEXUS_RAG_INTERNAL_URL=http://rag-mcp:8000/internal/graph-sync/sources
NEXUS_MEMORY_ROUTING_CONTRACT_ENABLED=true
NEXUS_HUMANIZER_RESPONSE_CONTRACT_ENABLED=true
NEXUS_INTERNAL_SYNC_KEY=replace-me-with-shared-internal-sync-key
