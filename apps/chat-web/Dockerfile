FROM node:20-alpine AS build

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .
ARG VITE_SUPABASE_URL
ARG VITE_SUPABASE_ANON_KEY
ARG VITE_CHATBOT_PROXY_URL
ARG NEXT_PUBLIC_CHATBOT_PROXY_URL
ARG VITE_CHAT_STREAM_FILE_HOSTS
ARG VITE_CHAT_ATTACHMENTS_BUCKET
ARG NEXT_PUBLIC_CHAT_ATTACHMENTS_BUCKET
ARG VITE_IMAGE_GENERATOR_API_URL
ARG VITE_API_BASE_URL
ARG NEXT_PUBLIC_API_BASE_URL
ENV VITE_SUPABASE_URL=$VITE_SUPABASE_URL \
    VITE_SUPABASE_ANON_KEY=$VITE_SUPABASE_ANON_KEY \
    VITE_CHATBOT_PROXY_URL=$VITE_CHATBOT_PROXY_URL \
    NEXT_PUBLIC_CHATBOT_PROXY_URL=$NEXT_PUBLIC_CHATBOT_PROXY_URL \
    VITE_CHAT_STREAM_FILE_HOSTS=$VITE_CHAT_STREAM_FILE_HOSTS \
    VITE_CHAT_ATTACHMENTS_BUCKET=$VITE_CHAT_ATTACHMENTS_BUCKET \
    NEXT_PUBLIC_CHAT_ATTACHMENTS_BUCKET=$NEXT_PUBLIC_CHAT_ATTACHMENTS_BUCKET \
    VITE_IMAGE_GENERATOR_API_URL=$VITE_IMAGE_GENERATOR_API_URL \
    VITE_API_BASE_URL=$VITE_API_BASE_URL \
    NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
RUN npm run build


FROM nginx:1.27-alpine

RUN addgroup -g 1001 -S app && adduser -S -D -H -u 1001 -G app app

COPY nginx.conf /etc/nginx/nginx.conf
COPY --from=build /app/dist /usr/share/nginx/html

RUN chown -R 1001:1001 /usr/share/nginx/html

USER 1001

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]
