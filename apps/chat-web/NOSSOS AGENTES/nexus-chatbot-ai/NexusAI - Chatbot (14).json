    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst userMessage = String(item.json.userMessage ?? item.json.body?.message ?? '').trim();\n\nconst ensSignals = [\n  'curso', 'cursos', 'certificação', 'certificacao', 'extensão', 'extensao', 'pós', 'pos', 'graduação', 'graduacao',\n  'matrícula', 'matricula', 'inscrição', 'inscricao', 'preço', 'preco', 'valor', 'investimento', 'datas', 'data',\n  'turma', 'cronograma', 'carga horária', 'carga horaria', 'ementa', 'grade', 'modalidade', 'presencial', 'ead',\n  'online', 'híbrido', 'hibrido'\n];\n\nconst marketingSignals = [\n  'copy', 'copywriting', 'headline', 'cta', 'criativo', 'anúncio', 'anuncio', 'tráfego', 'trafego', 'remarketing',\n  'funil', 'objeção', 'objecao', 'script', 'roteiro', 'tom de voz', 'mensagem', 'whatsapp', 'dm', 'landing',\n  'landing page', 'e-mail', 'email', 'campanha', 'conversão', 'conversao', 'ads', 'meta', 'google ads'\n];\n\nconst msg = userMessage.toLowerCase();\nconst hits = (signals) => signals.filter((s) => msg.includes(s)).slice(0, 8);\n\nconst ensHits = hits(ensSignals);\nconst marketingHits = hits(marketingSignals);\n\nconst needsEns = ensHits.length > 0;\nconst needsMarketing = marketingHits.length > 0;\n\nconst route = needsEns && needsMarketing ? 'both' : needsEns ? 'ens' : needsMarketing ? 'marketing' : 'both';\n\nreturn [\n  {\n    json: {\n      ...item.json,\n      query_route: route,\n      query_signals: {\n        ens: ensHits,\n        marketing: marketingHits,\n      },\n    },\n    binary: item.binary,\n  },\n];"
      },
      "id": "5d9dd74b-2160-49c8-9194-b9376de7809f",
      "name": "Query Processor",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        8800,
        11488
      ]
    },
    {
      "parameters": {
