      "typeVersion": 1
    },
    {
      "parameters": {
        "content": "# Phase 2: Google Drive Folder Monitoring Configuration",
        "height": 480,
        "width": 1264,
        "color": 2
      },
      "id": "ba65686c-4360-466a-8ccd-16c1e0cdc868",
      "name": "Sticky Note1",
