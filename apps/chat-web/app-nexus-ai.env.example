VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=SEU_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=SEU_SUPABASE_SERVICE_ROLE_KEY

# Bridge Nexus/Hermes exposta pelo Traefik.
VITE_CHATBOT_PROXY_URL=https://chat-api.solucoes-nexus.tech
NEXT_PUBLIC_CHATBOT_PROXY_URL=https://chat-api.solucoes-nexus.tech

# API Server do Hermes. Preferir URL interna Docker quando o compose do Hermes
# estiver conectado na rede nexus-hermes-net. Exemplo:
# HERMES_API_BASE_URL=http://hermes-api:8000
HERMES_API_BASE_URL=http://NOME_DO_SERVICO_HERMES:PORTA
HERMES_API_KEY=
HERMES_MODEL_NAME=hermes-agent
HERMES_SESSIONS_API_ENABLED=true
HERMES_RUN_POLL_MS=2000
BRIDGE_ALLOWED_ORIGINS=https://chat.solucoes-nexus.tech

# Hosts publicos que podem virar preview/download no chat.
VITE_CHAT_STREAM_FILE_HOSTS=https://jhbakzkqamgddphwakjj.supabase.co

VITE_CHAT_ATTACHMENTS_BUCKET=chat-attachments
NEXT_PUBLIC_CHAT_ATTACHMENTS_BUCKET=
