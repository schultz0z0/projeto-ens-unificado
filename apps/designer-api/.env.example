# ============================================================
# ENS AI Banner Factory — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# ============================================================

# --- Google AI Studio (Gemini API) ---
GEMINI_API_KEY=sua-api-key-do-gemini-ai-studio

# --- Modelos ---
IMAGEN_MODEL=gemini-3-pro-image-preview
GEMINI_MODEL=gemini-2.0-flash-001

# Compatibilidade legada (opcional)
GOOGLE_API_KEY=

# --- Configurações do Pipeline ---
OUTPUTS_DIR=outputs
TMP_DIR=.tmp
MAX_SAFETY_RETRIES=3

# --- Supabase Outputs ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_OUTPUTS_BUCKET=image-gen-outputs
SUPABASE_OUTPUTS_METADATA_ENABLED=false
SUPABASE_SIGNED_URL_EXPIRES_SECONDS=3600
SUPABASE_UPLOAD_MAX_ATTEMPTS=3
SUPABASE_UPLOAD_BACKOFF_SECONDS=1
